---
// PRD-700-R9 — Astro page that renders the root index.
// The HTML routing is non-normative for ACT (PRD-700 § Implementation notes);
// the ACT artifacts under `dist/.well-known/` and `dist/act/` are derived
// independently by the @act-spec/astro integration from `src/content/docs/`.
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
docs.sort((a, b) => a.slug.localeCompare(b.slug));
// Strip trailing `/` from `Astro.url.base` then re-add per link to keep
// hrefs root-relative under the deployed sub-path.
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
---

<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <title>Tinybox API Documentation</title>
    <link rel="canonical" href="https://example.com/" />
  </head>
  <body>
    <h1>Tinybox API Documentation</h1>
    <p>
      Reference build for PRD-700 of the ACT (Agent Content Tree) v0.1
      specification. The ACT artifact set lives at
      <a href={`${base}/.well-known/act.json`}>{base}/.well-known/act.json</a>.
    </p>
    <ul>
      {docs
        .filter((d) => d.slug !== 'index')
        .map((d) => (
          <li><a href={`${base}/${d.slug}/`}>{d.data.title}</a></li>
        ))}
    </ul>
  </body>
</html>

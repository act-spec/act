---
import Site from '../../layouts/Site.astro';
import {
  CATEGORIES,
  loadProductsInCategory,
  type CategoryId,
} from '../../lib/products.ts';

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.id } }));
}

const { category } = Astro.params;
const cat = CATEGORIES.find((c) => c.id === category);
if (!cat) return Astro.redirect('/');
const products = await loadProductsInCategory(cat.id as CategoryId);
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
---
<Site title={`${cat.title} — Acme Catalog`}>
  <p style="margin:0;font-size:13px;">
    <a href={`${base}/`}>← All categories</a>
  </p>
  <div style="font-family:ui-monospace,monospace;color:var(--muted);font-size:12px;margin-top:24px;">{cat.id}</div>
  <h1 style="margin:6px 0 8px;">{cat.title}</h1>
  <p style="color:var(--muted);margin:0 0 8px;">
    {products.length} products in this category. Same scope as the ACT subtree.
  </p>
  <p style="color:var(--muted);font-size:13px;margin:0 0 24px;font-family:ui-monospace,monospace;">
    /act/nodes/{cat.id}.json
  </p>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;">
    {products.map((p) => (
      <a
        href={`${base}/p/${p.sku}/`}
        style="background:var(--card);border:1px solid var(--line);border-radius:8px;padding:16px;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:8px;"
      >
        <img
          src={`${base}/thumb.svg`}
          alt=""
          loading="lazy"
          style="width:100%;aspect-ratio:3/2;object-fit:cover;border-radius:6px;border:1px solid var(--line);background:var(--bg);"
        />
        <div style="font-family:ui-monospace,monospace;color:var(--muted);font-size:12px;">{p.sku}</div>
        <div style="font-weight:600;">{p.name}</div>
        <div style="color:var(--muted);font-size:13px;">{p.summary}</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px;">
          {p.tags.slice(1, 4).map((t) => (
            <span style="background:var(--bg);border:1px solid var(--line);border-radius:999px;padding:2px 8px;font-size:11px;color:var(--muted);">
              {t}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Site>

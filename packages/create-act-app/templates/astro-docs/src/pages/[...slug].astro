---
// PRD-700-R9 — dynamic route for every doc node.
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  // `entry.slug` is the path-style slug without the `.md`/`.mdx` extension,
  // so pages are emitted at `/quickstart/index.html` instead of the
  // accidental `/quickstart.md/index.html` produced by `entry.id`.
  return docs
    .filter((d) => d.slug !== 'index')
    .map((d) => ({
      params: { slug: d.slug },
      props: { entry: d },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <title>{entry.data.title} — Tinybox</title>
    <meta name="description" content={entry.data.summary} />
  </head>
  <body>
    <h1>{entry.data.title}</h1>
    <p><em>{entry.data.summary}</em></p>
    <Content />
    <hr />
    <p><a href="/">← Tinybox home</a></p>
  </body>
</html>

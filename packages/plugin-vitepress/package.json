{
  "name": "@act-spec/plugin-vitepress",
  "version": "0.2.0",
  "description": "VitePress plugin for the ACT (Agent Content Tree) reference implementation. Wraps the ACT generator pipeline against VitePress 1.x / 2.x via the transformPageData and buildEnd hooks.",
  "license": "Apache-2.0",
  "author": "Jeremy Forsythe <jeremy@act-spec.org>",
  "homepage": "https://act-spec.org",
  "bugs": {
    "url": "https://github.com/act-spec/act/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/act-spec/act.git",
    "directory": "packages/plugin-vitepress"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vitepress": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "vitepress": {
      "optional": true
    }
  },
  "dependencies": {
    "@act-spec/adapter-markdown": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/generator-core": "workspace:*"
  },
  "devDependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/validator": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

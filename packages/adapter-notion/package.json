{
  "name": "@act-spec/adapter-notion",
  "version": "0.2.0-rc.1",
  "description": "Notion adapter for ACT (Agent Content Tree). Consumes the Notion API (databases.query, pages.retrieve, blocks.children.list) and emits ACT envelopes against the shared adapter framework. Supports database-as-branch / page-as-leaf mapping, block-tree to prose conversion, and per-page locale extraction from a configurable Notion property.",
  "license": "Apache-2.0",
  "author": "Jeremy Forsythe <jeremy@act-spec.org>",
  "homepage": "https://act-spec.org",
  "bugs": {
    "url": "https://github.com/act-spec/act/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/act-spec/act.git",
    "directory": "packages/adapter-notion"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "dependencies": {
    "@act-spec/adapter-framework": "workspace:*",
    "@act-spec/core": "workspace:*",
    "@act-spec/validator": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

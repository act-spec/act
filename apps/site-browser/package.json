{
  "name": "@act-spec/site-browser",
  "version": "0.0.0",
  "private": true,
  "description": "Hosted ACT site browser SPA — paste a URL, walk the tree, inspect the envelopes. Deploys to GitHub Pages at /browser/.",
  "license": "Apache-2.0",
  "author": "Jeremy Forsythe <jeremy@act-spec.org>",
  "homepage": "https://act-spec.org",
  "bugs": {
    "url": "https://github.com/act-spec/act/issues"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/act-spec/act.git",
    "directory": "apps/site-browser"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "conformance": "tsx conformance.ts"
  },
  "dependencies": {
    "@act-spec/core": "workspace:*",
    "@act-spec/inspector": "workspace:*",
    "@act-spec/validator": "workspace:*",
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}

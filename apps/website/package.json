{
  "name": "@act-spec/website",
  "version": "0.2.0",
  "private": true,
  "description": "Astro Starlight homepage for ACT (Agent Content Tree). Renders the v0.2 spec, marketing pages, examples gallery, blog, and governance docs at https://act-spec.org. Eats own dogfood by registering @act-spec/plugin-astro.",
  "license": "Apache-2.0",
  "author": "Jeremy Forsythe <jeremy@act-spec.org>",
  "homepage": "https://act-spec.org",
  "bugs": {
    "url": "https://github.com/act-spec/act/issues"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/act-spec/act.git",
    "directory": "apps/website"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "pnpm run build && astro preview",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "node -e \"console.log('@act-spec/website: lint covered by astro check')\"",
    "test": "node -e \"console.log('@act-spec/website: exercises end-to-end via conformance')\"",
    "conformance": "pnpm run build && tsx conformance.ts"
  },
  "dependencies": {
    "astro": "^4.16.19",
    "@astrojs/starlight": "^0.29.3",
    "@act-spec/plugin-astro": "workspace:*",
    "@act-spec/adapter-markdown": "workspace:*",
    "marked": "^14.1.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@act-spec/validator": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
